# ===========================================
# AmStar Amateur Football Platform
# Production Environment Variables
# ===========================================

# -----------------
# General Settings
# -----------------
# Domain for production deployment (used by Caddy)
DOMAIN=amstar.example.com

# Environment
NODE_ENV=production

# -----------------
# Database Settings
# -----------------
POSTGRES_USER=amstar
POSTGRES_PASSWORD=change-this-to-a-very-secure-password
POSTGRES_DB=amstar_db

# Database URL for backend (automatically constructed in docker-compose)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://amstar:change-this-to-a-very-secure-password@db:5432/amstar_db

# -----------------
# Backend Settings
# -----------------
# Security - MUST change in production
SECRET_KEY=change-this-to-a-very-long-random-secret-key-at-least-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Origins (JSON array format)
# For production, specify your domain(s)
BACKEND_CORS_ORIGINS=["https://amstar.example.com","https://www.amstar.example.com"]

# Debug mode (always false in production)
DEBUG=false

# -----------------
# Frontend Settings
# -----------------
# API Base URL for frontend
# Production: https://your-domain.com/api/v1
VITE_API_BASE_URL=https://amstar.example.com/api/v1

# -----------------
# Email Settings (Optional)
# -----------------
SMTP_TLS=true
SMTP_PORT=587
SMTP_HOST=smtp.gmail.com
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
EMAILS_FROM_EMAIL=noreply@amstar.example.com
EMAILS_FROM_NAME=AmStar Platform
