# Frontend-Specific .gitignore (Nuxt 3)
# This file is supplementary to the root .gitignore
# Only include frontend-specific patterns here

# NUXT 3 BUILD OUTPUT

# Nuxt build directories
.nuxt/
.output/
dist/

# Nuxt cache
.nuxt-cache/

# NODE.JS / NPM

# Dependencies (CRITICAL - NEVER COMMIT)
node_modules/

# Package manager files
.pnpm-store/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# Lock files (keep package-lock.json)
# yarn.lock  # Uncomment if using npm instead of yarn
# pnpm-lock.yaml  # Uncomment if using npm instead of pnpm

# ENVIRONMENT & CONFIGURATION

# Environment files
.env
.env.*
!.env.example

# Local configuration
.nuxtrc

# TESTING & COVERAGE

# Test coverage
coverage/
.nyc_output/

# LOGS

# All log files
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# VITE / BUILD TOOLS

# Vite cache
.vite/
.vite-cache/

# TypeScript
*.tsbuildinfo

# IDE & EDITOR

# VSCode
.vscode/
!.vscode/extensions.json

# WebStorm / IntelliJ
.idea/

# OPERATING SYSTEM

# macOS
.DS_Store

# Windows
Thumbs.db

# TEMPORARY FILES

# Temporary files
*.tmp
*.temp
.cache/

# PROJECT-SPECIFIC

# Old/backup directories
src_backup*/
*_backup_*/

# Generated documentation
/docs/api/

# Storybook build
storybook-static/

# KEEP THESE FILES (whitelist)

# Keep example files
!.env.example
!nuxt.config.ts
!package.json
