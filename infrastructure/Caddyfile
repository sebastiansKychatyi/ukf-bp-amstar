# =================================================================
# Unified Caddy gateway
#
# Environment variables injected by docker-compose:
#   DOMAIN             — AmStar domain,         e.g. amstar.example.com
#   PROJECT1_DOMAIN    — First project's domain, e.g. other.example.com
#   PROJECT1_UPSTREAM  — container:port on web_network, e.g. app:3000
#
# TESTING vs PRODUCTION mode — see the global block below.
# =================================================================

{
    # ---------------------------------------------------------------
    # TESTING MODE  (ports 8080:80 / 8443:443)
    #
    # When Caddy is NOT reachable on standard ports 80/443 from the
    # internet, Let's Encrypt's ACME HTTP-01 challenge cannot succeed.
    # Caddy will crash-loop trying to obtain a certificate.
    # `auto_https off` disables ACME — Caddy serves plain HTTP only.
    #
    # REMOVE THIS LINE when you move to real ports 80/443 in production.
    # ---------------------------------------------------------------
    auto_https off
}

# =================================================================
# AMSTAR
# =================================================================
{$DOMAIN:localhost} {

    log {
        output file /var/log/caddy/amstar-access.log
        format json
    }

    # Gateway-level health check (answered by Caddy itself, no upstream)
    handle /health {
        respond "OK" 200
    }

    # User-uploaded media files
    handle /media/* {
        root * /var/www/media
        file_server browse
    }

    # REST API
    handle /api/* {
        reverse_proxy amstar_backend:8000 {
            health_uri      /health
            health_interval 30s
            health_timeout  10s
            header_up Host              {host}
            header_up X-Real-IP         {remote_host}
            header_up X-Forwarded-For   {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # OpenAPI interactive docs
    handle /docs* {
        reverse_proxy amstar_backend:8000 {
            header_up Host              {host}
            header_up X-Real-IP         {remote_host}
            header_up X-Forwarded-For   {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    handle /redoc* {
        reverse_proxy amstar_backend:8000 {
            header_up Host              {host}
            header_up X-Real-IP         {remote_host}
            header_up X-Forwarded-For   {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    handle /openapi.json {
        reverse_proxy amstar_backend:8000 {
            header_up Host              {host}
            header_up X-Real-IP         {remote_host}
            header_up X-Forwarded-For   {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Nuxt.js SPA (nginx) — catch-all (must be last)
    handle /* {
        reverse_proxy amstar_frontend:80 {
            header_up Host              {host}
            header_up X-Real-IP         {remote_host}
            header_up X-Forwarded-For   {remote_host}
            header_up X-Forwarded-Proto {scheme}
            header_up Connection        {>Connection}
            header_up Upgrade           {>Upgrade}
        }
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options    "nosniff"
        X-XSS-Protection          "1; mode=block"
        X-Frame-Options           "SAMEORIGIN"
        Referrer-Policy           "strict-origin-when-cross-origin"
        -Server
    }

    encode gzip zstd
}

# =================================================================
# PROJECT 1  (remove this block entirely if not needed)
# =================================================================
{$PROJECT1_DOMAIN:_noop} {

    log {
        output file /var/log/caddy/project1-access.log
        format json
    }

    reverse_proxy {$PROJECT1_UPSTREAM:localhost:9} {
        header_up Host              {host}
        header_up X-Real-IP         {remote_host}
        header_up X-Forwarded-For   {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "SAMEORIGIN"
        Referrer-Policy           "strict-origin-when-cross-origin"
        -Server
    }

    encode gzip zstd
}
