*.sublime-workspace
.sublime-gulp.cache

# Vim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]
Session.vim
Sessionx.vim
.netrwhist
tags
[._]*.un~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# ============================================================================
# BUILD ARTIFACTS & TEMPORARY FILES
# ============================================================================

# Compiled files
*.com
*.class
*.dll
*.exe
*.o
*.pyc
*.pyo

# Archives
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.zip

# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~
.#*

# ============================================================================
# CLOUD & DEPLOYMENT
# ============================================================================

# Terraform
.terraform/
*.tfstate
*.tfstate.*
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
