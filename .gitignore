# ============================================================================
# AmStar Football Platform - Master .gitignore
# ============================================================================
# This file prevents sensitive, temporary, and auto-generated files from
# being tracked by Git version control.
#
# Project Structure:
# - Root: Docker, environment variables, documentation
# - Frontend: Nuxt 3 (Node.js)
# - Backend: FastAPI (Python)
# ============================================================================

# ============================================================================
# ENVIRONMENT & SECRETS (CRITICAL - NEVER COMMIT)
# ============================================================================
# Environment files contain sensitive data like API keys, database passwords,
# and secrets. These must NEVER be committed to version control.

.env
.env.*
.env.local
.env.production
.env.development
!.env.example

# Backup files that might contain sensitive data
*.backup
*.bak
*.old

# ============================================================================
# PYTHON / FASTAPI (Backend)
# ============================================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/
ENV/
backend/.venv/
backend/venv/

# Python distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.log
.pytest_cache/
.hypothesis/

# Flask/Django stuff (if used)
instance/
.webassets-cache
db.sqlite3
db.sqlite3-journal

# Scrapy stuff
.scrapy

# Sphinx documentation
docs/_build/

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
.python-version

# Celery
celerybeat-schedule
celerybeat.pid

# SageMath
*.sage.py

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# pytype static type analyzer
.pytype/

# Cython debug symbols
cython_debug/

# ============================================================================
# NODE.JS / NUXT 3 (Frontend)
# ============================================================================

# Dependencies
node_modules/
frontend/node_modules/
jspm_packages/
bower_components/

# Nuxt build output
.nuxt/
.output/
frontend/.nuxt/
frontend/.output/

# Nuxt generate output
dist/
frontend/dist/

# Vite cache
.vite/
frontend/.vite/

# Package manager lock files (keep package-lock.json but ignore yarn.lock)
# Uncomment if using yarn:
# yarn.lock
# pnpm-lock.yaml

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Diagnostic reports
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory
coverage/
*.lcov

# nyc test coverage
.nyc_output

# Grunt intermediate storage
.grunt

# Nuxt cache
.nuxtrc
.nuxt-cache/

# Nuxt TypeScript
*.tsbuildinfo
next-env.d.ts

# ============================================================================
# DOCKER
# ============================================================================

# Docker volumes and data directories
**/volumes/
**/data/
database/data/
db/data/

# Docker override files (keep base docker-compose files)
docker-compose.override.yml

# ============================================================================
# DATABASE
# ============================================================================

# SQLite databases
*.sqlite
*.sqlite3
*.db

# PostgreSQL
*.pgsql
*.sql.gz

# Database dumps
*.dump
*.sql
!database/init.sql
!backend/app/sql/

