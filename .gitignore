terraform.rc

# Kubernetes
*.kubeconfig

# ============================================================================
# TESTING & CI/CD
# ============================================================================

# Test coverage
.coverage
htmlcov/
.pytest_cache/

# CI/CD artifacts
.github/workflows/*.yml.bak

# ============================================================================
# DOCUMENTATION (Generated)
# ============================================================================

# Auto-generated docs
/docs/_build/
/docs/api/
site/

# ============================================================================
# PROJECT-SPECIFIC
# ============================================================================

# User uploads (if any)
/backend/uploads/
/frontend/static/uploads/
/public/uploads/

# Cache directories
.cache/
.parcel-cache/

# Backup directories
backup/
backups/
*.backup/

# Logs directory
logs/
*.log

# ============================================================================
# IMPORTANT: Files to KEEP (whitelist)
# ============================================================================
# These files SHOULD be committed despite being in ignored directories

# Keep example environment files
!.env.example
!backend/.env.example
!frontend/.env.example

# Keep README files everywhere
!**/README.md

# Keep database initialization scripts
!database/init/
!backend/app/sql/

# Keep Docker configuration
!Dockerfile
!docker-compose*.yml
!.dockerignore

# Keep CI/CD configuration
!.github/workflows/
!.gitlab-ci.yml

# ============================================================================
# END OF .gitignore
# ============================================================================
