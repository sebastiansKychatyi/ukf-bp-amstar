# ===========================================
# AmStar Amateur Football Platform
# Local Development Environment Variables
# ===========================================

# -----------------
# General Settings
# -----------------
NODE_ENV=development

# -----------------
# Database Settings
# -----------------
# Default database credentials for local development
DB_NAME=amstar_db
DB_USER=amstar
DB_PASSWORD=amstar_dev_password

POSTGRES_USER=amstar
POSTGRES_PASSWORD=amstar_dev_password
POSTGRES_DB=amstar_db

# Database URL for backend
DATABASE_URL=postgresql://amstar:amstar_dev_password@db:5432/amstar_db

# -----------------
# Backend Settings
# -----------------
# Security (development keys - DO NOT use in production)
SECRET_KEY=dev-secret-key-change-in-production-12345678900987654321
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Origins (allow local development ports)
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:8080"]

# Debug mode
DEBUG=true

# Enable hot reload
RELOAD=true

# -----------------
# Frontend Settings
# -----------------
# API Base URL for frontend (points to local backend)
# Local development: http://localhost:8000/api/v1
VITE_API_BASE_URL=http://localhost:8000/api/v1

# -----------------
# Email Settings (Optional - can be left empty for local dev)
# -----------------
SMTP_TLS=true
SMTP_PORT=587
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@amstar.local
EMAILS_FROM_NAME=AmStar Platform (Dev)
