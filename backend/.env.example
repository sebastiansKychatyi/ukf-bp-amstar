# ============================================
# AmStar Football Platform - Environment Configuration
# ============================================
# SECURITY WARNING: This is an EXAMPLE file. DO NOT use these values in production!
# Copy this file to .env and replace all values with secure production values.

# ============================================
# REQUIRED SETTINGS
# ============================================

# Secret key for JWT token generation
# Generate with: openssl rand -hex 32
# Or: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_SECURE_64_CHAR_SECRET_KEY_GENERATED_WITH_OPENSSL

# Database connection URL
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://amstar_user:REPLACE_WITH_DB_PASSWORD@localhost:5432/amstar_db

# ============================================
# APPLICATION SETTINGS
# ============================================

# Application name
PROJECT_NAME=AmStar Football Platform

# API version
VERSION=1.0.0
API_V1_STR=/api/v1

# Environment (development, staging, production)
ENVIRONMENT=development

# Debug mode (set to False in production!)
DEBUG=True

# ============================================
# SECURITY SETTINGS
# ============================================

# CORS allowed origins (comma-separated list)
# Development example:
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
# Production example:
# BACKEND_CORS_ORIGINS=["https://amstar.com","https://www.amstar.com"]

# JWT token expiration (in minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# RATE LIMITING
# ============================================

# Enable rate limiting
RATE_LIMIT_ENABLED=True

# Global rate limit (requests per minute)
RATE_LIMIT_REQUESTS=100

# Authentication endpoint rate limit (requests per minute)
AUTH_RATE_LIMIT_REQUESTS=5

# ============================================
# REDIS SETTINGS (for rate limiting & token blacklist)
# ============================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=  # Uncomment if Redis requires authentication

# ============================================
# EMAIL SETTINGS (for notifications)
# ============================================

# SMTP server configuration
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-specific-password
# SMTP_FROM_EMAIL=noreply@amstar.com
# SMTP_FROM_NAME=AmStar Platform

# ============================================
# FILE UPLOAD SETTINGS
# ============================================

# Maximum file size for team logos (in MB)
MAX_UPLOAD_SIZE_MB=5

# Allowed image formats
ALLOWED_IMAGE_FORMATS=["jpg","jpeg","png","webp"]

# Upload directory
UPLOAD_DIR=./uploads

# ============================================
# LOGGING
# ============================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log format (json, text)
LOG_FORMAT=json

# ============================================
# PRODUCTION CHECKLIST
# ============================================
# Before deploying to production, ensure:
# [ ] SECRET_KEY is a secure 64-character random string
# [ ] DATABASE_URL uses strong password and secure connection
# [ ] DEBUG is set to False
# [ ] ENVIRONMENT is set to "production"
# [ ] BACKEND_CORS_ORIGINS contains only your production domains
# [ ] RATE_LIMIT_ENABLED is True
# [ ] Redis is properly secured (password, firewall)
# [ ] All passwords are strong and unique
# [ ] SSL/TLS is configured for database and Redis connections
# [ ] SMTP credentials are configured for email notifications
